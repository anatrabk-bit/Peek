# =============================================================================
# Peek — environment variables
# Copy to .env.local for local dev. Add the same keys in Vercel → Settings →
# Environment Variables (see deployment notes for which go where).
# =============================================================================

# --- Supabase (required) ---
# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose in the browser (RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — SERVER ONLY. Never expose to the client.
# Supabase → Settings → API → service_role (secret JWT eyJ...) OR Secret keys (sb_secret_...)
# For peek-eta.vercel.app: add here AND in Vercel Environment Variables, then Redeploy.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email allowed to access /admin (server-only; optional if set in lib/admin.ts)
ADMIN_EMAIL=your_admin_email@example.com

# Resend — email you when someone new signs up (server-only)
# https://resend.com — same key can power Supabase edge functions
RESEND_API_KEY=re_xxxxxxxx

# --- Google Maps (required for post-request autocomplete and browse map) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Site URL (production) ---
NEXT_PUBLIC_SITE_URL=https://peek-eta.vercel.app

# Optional: Ko-fi, Buy Me a Coffee, or mailto link for support / voucher redemption
NEXT_PUBLIC_SUPPORT_URL=https://your-support-link.example.com

# --- Web Push — browser notifications for Peeks ---
# Public key: used client-side when subscribing to push (NEXT_PUBLIC_ required)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# --- Supabase Edge Function secrets (NOT in Vercel — set in Supabase Dashboard) ---
# notify-nearby-runners (push alerts for Peeks):
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_PUBLIC_KEY=your_vapid_public_key

# notify-requester (email when answer is ready — https://resend.com):
# RESEND_API_KEY=re_xxxxxxxx
# NOTIFY_FROM_EMAIL=Peek <onboarding@resend.dev>
