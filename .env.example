# =============================================================================
# Peek — environment variables
# Copy to .env.local for local dev. Add the same keys in Vercel → Settings →
# Environment Variables (see deployment notes for which go where).
# =============================================================================

# --- Supabase (required) ---
# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose in the browser (RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — SERVER ONLY. Never expose to the client.
# Used by /admin to list users and manage requests.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email allowed to access /admin (server-only; optional if set in lib/admin.ts)
ADMIN_EMAIL=your_admin_email@example.com

# Resend — email you when someone new signs up (server-only)
# https://resend.com — same key can power Supabase edge functions
RESEND_API_KEY=re_xxxxxxxx
NOTIFY_FROM_EMAIL=Peek <onboarding@resend.dev>

# --- Google Maps (required for post-request autocomplete and browse map) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Client payments (requesters pay by card) ---
# Active provider is chosen automatically: Stripe → PayPal → manual (pilot).
# To switch later, set the env keys for the provider you want.

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# stripe listen --forward-to localhost:3001/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal Business (optional — card + Apple Pay via PayPal checkout)
# developer.paypal.com → Apps & Credentials
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
NEXT_PUBLIC_PAYPAL_CLIENT_ID=...
# sandbox or live
PAYPAL_MODE=sandbox

# --- Manual payment (pilot — when no card provider is configured) ---
# Shown to requesters on My requests while payment is pending.
PEEK_PAYMENT_ACCOUNT_NAME=Your Business Name
PEEK_PAYMENT_SORT_CODE=00-00-00
PEEK_PAYMENT_ACCOUNT_NUMBER=12345678
# Optional hint shown under the payment reference
PEEK_PAYMENT_REFERENCE_HINT=Use your request title as the payment reference.

# --- Web Push — browser notifications for Peeks ---
# Public key: used client-side when subscribing to push (NEXT_PUBLIC_ required)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# --- Supabase Edge Function secrets (NOT in Vercel — set in Supabase Dashboard) ---
# notify-nearby-runners (push alerts for Peeks):
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_PUBLIC_KEY=your_vapid_public_key

# notify-requester (email when answer is ready — https://resend.com):
# RESEND_API_KEY=re_xxxxxxxx
# NOTIFY_FROM_EMAIL=Peek <onboarding@resend.dev>
