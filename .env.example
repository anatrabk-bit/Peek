# =============================================================================
# Peek — environment variables
# Copy to .env.local for local dev. Add the same keys in Vercel → Settings →
# Environment Variables (see deployment notes for which go where).
# =============================================================================

# --- Supabase (required) ---
# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose in the browser (RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — SERVER ONLY. Never expose to the client.
# Used by /admin to list users and manage requests.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email allowed to access /admin (server-only; optional if set in lib/admin.ts)
ADMIN_EMAIL=your_admin_email@example.com

# --- Google Maps (required for post-request autocomplete and browse map) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Web Push — browser notifications for Peeks ---
# Public key: used client-side when subscribing to push (NEXT_PUBLIC_ required)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# --- Supabase Edge Function only (NOT set in Vercel) ---
# Set these as secrets in Supabase → Edge Functions → notify-nearby-runners
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_PUBLIC_KEY=your_vapid_public_key
